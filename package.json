{
  "name": "@floschl/opencode-tmux",
  "version": "0.3.0",
  "description": "Minimal OpenCode plugin: auto-spawn tmux panes for subagent sessions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tmux",
    "subagent"
  ],
  "license": "MIT",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external @opencode-ai/plugin && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test --coverage --isolate"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.17"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.17",
    "@types/node": "^24.0.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.0"
  }
}
